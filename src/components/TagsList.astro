---
interface Props {
  tags: string[];
  showCounts?: boolean;
  counts?: Record<string, number>;
  class?: string;
}

const { tags, showCounts = false, counts = {}, class: className = "" } = Astro.props;

if (!tags || tags.length === 0) {
  return null;
}
---

<div class={`font-serif text-sm md:text-base flex flex-wrap not-prose ${className}`}>
  {tags.map((tag) => (
    <a
      href={`/tags/${tag.toLowerCase()}`}
      class="text-ink hover:text-accent underline-offset-4 hover:underline pr-3"
    >
      {tag}
      {showCounts && counts[tag] && (
        <span class="font-mono text-xs text-faint">({counts[tag]})</span>
      )}
    </a>
  ))}
</div>
