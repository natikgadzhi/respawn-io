---
import { config } from "../../blog.config";

const { pathname } = Astro.url;
const isHomepage = pathname === "/";
---

{isHomepage ? (
  <h1 class="font-serif text-2xl md:text-3xl font-semibold text-ink leading-tight">
    {config.title}
  </h1>
) : (
  <h2 class="font-serif text-2xl md:text-3xl font-semibold text-ink leading-tight">
    <a href="/" class="hover:text-accent">
      {config.title}
    </a>
  </h2>
)}
