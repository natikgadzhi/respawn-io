---
import { getCollection, render } from "astro:content";
import { config } from "../../blog.config";
import BaseLayout from "../layouts/BaseLayout.astro";

const pages = await getCollection("pages");
const aboutPage = pages.find((page) => page.id === "about" || page.id === "about.md");

if (!aboutPage) {
  return Astro.redirect("/404");
}

const { Content } = await render(aboutPage);
---

<BaseLayout title={config.title} description={config.meta.description}>
    <article
        class="prose prose-quoteless max-w-none mb-24
      prose-li:leading-relaxed
      prose-p:leading-relaxed
      prose-h1:text-3xl
      prose-h2:pt-6
      prose-h2:text-2xl
      prose-h2:font-semibold
      last-of-type:prose-p:mb-0
      lg:prose-p:mb-8
      prose-a:underline-offset-4
      hover:prose-a:text-accent-hover
      prose-blockquote:border-l-4
      prose-blockquote:font-normal
      prose-blockquote:not-italic
      md:prose-base
      lg:prose-base
      prose-pre:not-prose
      prose-pre:text-sm"
    >
        <Content />
    </article>
</BaseLayout>
