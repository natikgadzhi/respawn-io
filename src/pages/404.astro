---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404: Page Not Found">
  <section class="py-20 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-faint">Error 404</p>
    <h1 class="font-serif text-3xl md:text-4xl font-semibold text-ink mt-3 leading-tight">
      Page not found
    </h1>
    <p class="mt-4 text-muted">The page you're looking for doesn't exist.</p>
    <p class="mt-8">
      <a href="/" class="text-ink hover:text-accent underline-offset-4 hover:underline">
        Go back home
      </a>
    </p>
  </section>
</BaseLayout>
