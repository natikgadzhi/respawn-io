---
import { getCollection } from "astro:content";
import { config } from "../../../blog.config";
import DailyList from "../../components/DailyList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortDailyByDate } from "../../lib/content-utils";

const allDaily = await getCollection("daily", ({ data }) => {
  if (import.meta.env.PROD) {
    return !data.draft;
  }
  return true;
});

const dailies = sortDailyByDate(allDaily);
---

<BaseLayout
  title={`TIL and Daily Notes: ${config.title}`}
  description={config.daily.description}
>
  <header class="mb-10">
    <h1 class="font-serif text-2xl md:text-3xl font-semibold text-ink">Daily Notes</h1>
    <p class="mt-2 text-muted text-base md:text-lg">{config.daily.description}</p>
  </header>

  <DailyList daily={dailies} />
</BaseLayout>
