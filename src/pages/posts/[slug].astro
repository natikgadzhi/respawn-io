---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Aside from "../../components/mdx/Aside.astro";
import LinkedHeaders from "../../components/mdx/LinkedHeaders.astro";
import Script from "../../components/mdx/Script.astro";
import WithAside from "../../components/mdx/WithAside.astro";
import TagsList from "../../components/TagsList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getOgImageUrl, getRawExcerpt } from "../../lib/content-utils";
import { titleCase } from "../../lib/titleCase";

export const getStaticPaths = (async () => {
  const allPosts = await getCollection("posts", ({ data }) => {
    // Filter out drafts and work-in-progress in production
    if (import.meta.env.PROD) {
      return !data.draft;
    }
    return true;
  });
  return allPosts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const postTitle = titleCase(post.data.title);
const rawExcerpt = getRawExcerpt(post.data.excerpt);
const ogImageUrl = getOgImageUrl(post.id);

// Use meta_description if available, otherwise use full excerpt (not truncated)
// This ensures descriptions are not too short
const description = post.data.meta_description || rawExcerpt;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);
}
---

<BaseLayout title={postTitle} description={description} ogImage={ogImageUrl} ogType="article">
  <article
    class="prose prose-quoteless max-w-none mb-24
      prose-li:leading-relaxed
      prose-p:leading-relaxed
      prose-h1:text-3xl
      prose-h2:pt-6
      prose-h2:text-2xl
      prose-h2:font-semibold
      last-of-type:prose-p:mb-0
      lg:prose-p:mb-8
      prose-a:underline-offset-4
      hover:prose-a:text-accent-hover
      prose-blockquote:border-l-4
      prose-blockquote:font-normal
      prose-blockquote:not-italic
      md:prose-base
      lg:prose-base
      prose-pre:not-prose
      prose-pre:text-sm
      prose-img:mx-auto"
  >
    <header class="not-prose mb-10">
      <h1 class="font-serif text-3xl md:text-4xl font-semibold text-ink leading-tight">{postTitle}</h1>
    </header>

    <div class="post-body">
      <Content components={{ LinkedHeaders, Aside, WithAside, Script }} />
    </div>

    <style is:inline>
      /* Hide a body-rendered H1 that duplicates the page header */
      .post-body > h1:first-child {
        display: none;
      }
    </style>

    <div class="text-2xl mt-20 mb-8 flex items-center justify-center text-faint">
      <div class="border-t border-rule grow"></div>
      <div class="px-4">⌘ ⌘ ⌘</div>
      <div class="border-t border-rule grow"></div>
    </div>

    {post.data.tags && post.data.tags.length > 0 && <TagsList tags={post.data.tags} class="mb-4" />}

    <div>
      Originally published on&nbsp;
      {formatDate(post.data.created)}.
    </div>
    {
      post.data.created.getTime() !== post.data.modified.getTime() && (
        <div>
          Last update on&nbsp;
          {formatDate(post.data.modified)}.
        </div>
      )
    }
  </article>
</BaseLayout>
